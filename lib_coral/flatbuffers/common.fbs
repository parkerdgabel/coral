enum DType: byte {
    BOOL = 0,
    INT8 = 1,
    UINT8 = 2,
    INT16 = 3,
    UINT16 = 4,
    INT32 = 5,
    UINT32 = 6,
    INT64 = 7,
    UINT64 = 8,
    FLOAT16 = 9,
    FLOAT32 = 10,
    FLOAT64 = 11,
    BFLOAT16 = 12,
}

struct Coord {
    coord: [ulong];
}

struct Shape {
    shape: [ulong];
}

enum Order: byte {
    ROW_MAJOR = 0,
    COLUMN_MAJOR = 1,
}
